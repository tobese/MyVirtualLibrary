<Page x:Class="VirtualLibrary.Client.Pages.BookDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Content="← Back" Click="OnBack" />
            <TextBlock Grid.Column="1" x:Name="TitleText" FontSize="24" FontWeight="SemiBold"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left">
                <TextBlock x:Name="AuthorsText" Opacity="0.7" />
                <TextBlock x:Name="PublisherText" Opacity="0.7" />
                <TextBlock x:Name="IsbnText" Opacity="0.7" />
                <TextBlock x:Name="DimensionsText" Opacity="0.7" />

                <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,12,0,0" />
                <ComboBox x:Name="StatusCombo" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="WantToRead" />
                    <ComboBoxItem Content="Owned" />
                    <ComboBoxItem Content="Read" />
                </ComboBox>

                <TextBlock Text="Rating (0–5)" FontWeight="SemiBold" Margin="0,12,0,0" />
                <Slider x:Name="RatingSlider" Minimum="0" Maximum="5" StepFrequency="1"
                        TickFrequency="1" SmallChange="1" />

                <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,12,0,0" />
                <TextBox x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="120" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.7" />
            <Button Grid.Column="1" Content="Delete" Click="OnDelete" />
            <Button Grid.Column="2" Content="Save" Click="OnSave" Style="{ThemeResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Page>
