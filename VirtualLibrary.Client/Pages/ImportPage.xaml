<Page x:Class="VirtualLibrary.Client.Pages.ImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Bulk Import" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="Pick a plain-text file with one ISBN per line. Lines starting with # are ignored."
                           Opacity="0.65" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" Content="Back" Click="OnBack"
                    VerticalAlignment="Top" />
        </Grid>

        <!-- File + options row -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="PickFileButton"
                    Content="Choose file…"
                    Click="OnPickFile" />

            <TextBlock Grid.Column="1" x:Name="FileNameText"
                       Text="No file selected"
                       VerticalAlignment="Center" Opacity="0.6"
                       TextTrimming="CharacterEllipsis" />

            <CheckBox Grid.Column="2" x:Name="OwnedCheck"
                      Content="Owned" IsChecked="True"
                      VerticalAlignment="Center" />

            <ComboBox Grid.Column="3" x:Name="StatusCombo" SelectedIndex="0">
                <ComboBoxItem Content="Want to read" />
                <ComboBoxItem Content="Read" />
            </ComboBox>

            <Button Grid.Column="4" x:Name="ImportButton"
                    Content="Import"
                    Click="OnImport"
                    IsEnabled="False" />
        </Grid>

        <!-- Status / progress -->
        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Text=""
                   Foreground="Red"
                   TextWrapping="Wrap" />

        <!-- Summary bar (visible after a completed import) -->
        <Border Grid.Row="3"
                x:Name="SummaryBorder"
                Visibility="Collapsed"
                Background="{ThemeResource SystemColorHighlightColor}"
                Opacity="0.12"
                CornerRadius="6"
                Padding="12,8">
            <TextBlock x:Name="SummaryText"
                       TextWrapping="Wrap"
                       FontSize="13" />
        </Border>

        <!-- Results log -->
        <ListView Grid.Row="4"
                  x:Name="ResultsList"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,6" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Name="IsbnText"
                                   FontFamily="Consolas,Courier New,monospace"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   x:Name="StatusLabel"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2"
                                   x:Name="TitleText"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Opacity="0.8" />
                        <TextBlock Grid.Column="3"
                                   x:Name="RefreshedText"
                                   Text="↻ refreshed"
                                   FontSize="11" Opacity="0.55"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
