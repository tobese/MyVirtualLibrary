<Page x:Class="VirtualLibrary.Client.Pages.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:shared="using:VirtualLibrary.Shared"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="← Back" Click="OnBack" />
            <TextBlock Grid.Column="1" Text="User Management" FontSize="24" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="Refresh" Click="OnRefresh" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="StatusFilter" SelectionChanged="OnFilterChanged"
                      HorizontalAlignment="Stretch" SelectedIndex="0">
                <ComboBoxItem Content="All" />
                <ComboBoxItem Content="PendingApproval" />
                <ComboBoxItem Content="Active" />
                <ComboBoxItem Content="Rejected" />
                <ComboBoxItem Content="Suspended" />
            </ComboBox>
            <TextBlock Grid.Column="1" x:Name="StatusText" VerticalAlignment="Center" Opacity="0.7" />
        </Grid>

        <ListView Grid.Row="2" x:Name="UsersList" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="shared:UserResponse">
                    <Grid Padding="8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{x:Bind Email}" FontWeight="SemiBold" />
                            <TextBlock Opacity="0.7" FontSize="12"
                                       Text="{x:Bind DisplayName}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Bind Role}" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Opacity="0.75" />
                        <TextBlock Grid.Column="2" Text="{x:Bind Status}" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Opacity="0.75" />
                        <Button Grid.Column="3" Content="Approve" Tag="{x:Bind Id}" Click="OnApprove"
                                Margin="0,0,4,0" />
                        <Button Grid.Column="4" Content="Suspend" Tag="{x:Bind Id}" Click="OnSuspend" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
