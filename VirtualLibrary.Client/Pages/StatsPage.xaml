<Page x:Class="VirtualLibrary.Client.Pages.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Library Statistics" FontSize="26" FontWeight="SemiBold" />
                <TextBlock x:Name="LastUpdatedText" Opacity="0.5" FontSize="12" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                <Button x:Name="RefreshButton" Content="Refresh" Click="OnRefresh" />
                <Button Content="Back" Click="OnBack" />
            </StackPanel>
        </Grid>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel" Spacing="28" Visibility="Collapsed">

                <!-- ── Catalogue ─────────────────────────────────── -->
                <StackPanel Spacing="10">
                    <TextBlock Text="CATALOGUE" FontSize="11" FontWeight="SemiBold"
                               Opacity="0.5" CharacterSpacing="150" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="EditionsCard"  MinWidth="100" />
                        <Border Grid.Column="1" x:Name="WorksCard"     MinWidth="100" />
                        <Border Grid.Column="2" x:Name="AuthorsCard"   MinWidth="100" />
                        <Border Grid.Column="3" x:Name="SubjectsCard"  MinWidth="100" />
                    </Grid>
                </StackPanel>

                <!-- ── Collection ────────────────────────────────── -->
                <StackPanel Spacing="10">
                    <TextBlock Text="COLLECTION" FontSize="11" FontWeight="SemiBold"
                               Opacity="0.5" CharacterSpacing="150" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="UserBooksCard"  MinWidth="100" />
                        <Border Grid.Column="1" x:Name="OwnedCard"      MinWidth="100" />
                        <Border Grid.Column="2" x:Name="WishlistCard"   MinWidth="100" />
                    </Grid>
                </StackPanel>

                <!-- ── Reading ────────────────────────────────────── -->
                <StackPanel Spacing="10">
                    <TextBlock Text="READING" FontSize="11" FontWeight="SemiBold"
                               Opacity="0.5" CharacterSpacing="150" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="ReadCard"        MinWidth="100" />
                        <Border Grid.Column="1" x:Name="UnreadCard"      MinWidth="100" />
                        <Border Grid.Column="2" x:Name="ReadRecordsCard" MinWidth="100" />
                        <Border Grid.Column="3" x:Name="MembersCard"     MinWidth="100" />
                    </Grid>
                </StackPanel>

                <!-- ── Top lists ──────────────────────────────────── -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Top authors -->
                    <StackPanel Grid.Column="0" Spacing="10">
                        <TextBlock Text="TOP AUTHORS" FontSize="11" FontWeight="SemiBold"
                                   Opacity="0.5" CharacterSpacing="150" />
                        <ListView x:Name="AuthorsList"
                                  SelectionMode="None"
                                  IsHitTestVisible="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="NameText" Grid.Column="0"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Background="{ThemeResource SystemAccentColor}"
                                                CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                                            <TextBlock x:Name="CountText"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="White" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- Top subjects -->
                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Text="TOP SUBJECTS" FontSize="11" FontWeight="SemiBold"
                                   Opacity="0.5" CharacterSpacing="150" />
                        <ListView x:Name="SubjectsList"
                                  SelectionMode="None"
                                  IsHitTestVisible="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="NameText" Grid.Column="0"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Background="{ThemeResource SystemAccentColor}"
                                                CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                                            <TextBlock x:Name="CountText"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="White" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading / error overlay -->
        <TextBlock Grid.Row="1"
                   x:Name="StatusText"
                   Text="Loading…"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.6" />
    </Grid>
</Page>
