<Page x:Class="VirtualLibrary.Client.Pages.DevLoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Padding="40">
        <StackPanel Spacing="12" MaxWidth="320">

            <TextBlock Text="DEV LOGIN"
                       FontSize="22" FontWeight="Bold"
                       Foreground="OrangeRed"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Quick-login as a test persona. Not available in production."
                       Opacity="0.6" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center" />

            <Button x:Name="SuperAdminButton"
                    Content="SuperAdmin  (Active)"
                    Tag="superadmin"
                    Click="OnPersonaClicked"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" />

            <Button x:Name="AdminButton"
                    Content="Admin  (Active)"
                    Tag="admin"
                    Click="OnPersonaClicked"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" />

            <Button x:Name="MemberButton"
                    Content="Member  (Active)"
                    Tag="member"
                    Click="OnPersonaClicked"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" />

            <Button x:Name="PendingButton"
                    Content="Pending User  (PendingApproval)"
                    Tag="pending"
                    Click="OnPersonaClicked"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" />

            <Button x:Name="SuspendedButton"
                    Content="Suspended User  (Suspended)"
                    Tag="suspended"
                    Click="OnPersonaClicked"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" />

            <TextBlock x:Name="StatusText"
                       Text=""
                       Foreground="Red"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" />

            <HyperlinkButton Content="Back to login"
                             Click="OnBackClicked"
                             HorizontalAlignment="Center" />

        </StackPanel>
    </Grid>
</Page>
