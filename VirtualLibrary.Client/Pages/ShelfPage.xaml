<Page x:Class="VirtualLibrary.Client.Pages.ShelfPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:VirtualLibrary.Client.Pages"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="&#8592; Back" Click="OnBack" />
            <TextBlock Grid.Column="1" Text="Virtual Shelf" FontSize="24" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="Refresh" Click="OnRefresh" />
        </Grid>

        <!--
            Reorderable shelf: horizontal ListView backed by ObservableCollection<SpineItem>.
            CanReorderItems + AllowDrop enable built-in drag-to-reorder on both WASM and Android.
            The DataTemplate renders each book as a spine with a variable width derived from
            Edition.PhysicalDimensions (falling back to 26 px) and a deterministic hue.
        -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollMode="Auto" VerticalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
            <Border BorderThickness="0,0,0,6" BorderBrush="#80A0522D" Padding="8,0,8,0">
                <ListView x:Name="SpinesList"
                          SelectionMode="None"
                          CanDragItems="True"
                          AllowDrop="True"
                          CanReorderItems="True"
                          DragItemsCompleted="OnDragCompleted"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.VerticalScrollMode="Disabled">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="3"
                                        VerticalAlignment="Bottom" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinWidth" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:SpineItem">
                            <Border Width="{x:Bind SpineWidth}" Height="180"
                                    Background="{x:Bind SpineColor}" CornerRadius="2"
                                    ToolTipService.ToolTip="{x:Bind Book.Edition.Title}">
                                <TextBlock Text="{x:Bind Book.Edition.Title}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="White" FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="170">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </ScrollViewer>

        <TextBlock Grid.Row="2" x:Name="StatusText" Opacity="0.6" HorizontalAlignment="Center" />
    </Grid>
</Page>
