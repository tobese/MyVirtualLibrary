<Page x:Class="VirtualLibrary.Client.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:shared="using:VirtualLibrary.Shared"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="My Library" FontSize="28" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Scan" Click="OnOpenScan" />
            <Button Grid.Column="2" Content="Shelf" Click="OnOpenShelf" />
            <Button Grid.Column="3" Content="Import" Click="OnOpenImport" />
            <Button Grid.Column="4" x:Name="AdminButton" Content="Users"
                    Click="OnOpenUserManagement" Visibility="Collapsed" />
            <Button Grid.Column="5" x:Name="StatsButton" Content="Stats"
                    Click="OnOpenStats" Visibility="Collapsed" />
            <Button Grid.Column="6" Content="Refresh" Click="OnRefresh" />
            <Button Grid.Column="7" Content="Sign out" Click="OnSignOut" />
        </Grid>

        <!-- Add book -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="IsbnBox" PlaceholderText="Enter ISBN-10 or ISBN-13"
                     KeyDown="OnIsbnKeyDown" />
            <CheckBox Grid.Column="1" x:Name="OwnedCheck" Content="Owned" IsChecked="True"
                      VerticalAlignment="Center" />
            <ComboBox Grid.Column="2" x:Name="StatusCombo" SelectedIndex="0">
                <ComboBoxItem Content="Want to read" />
                <ComboBoxItem Content="Read" />
            </ComboBox>
            <Button Grid.Column="3" Content="Add" Click="OnAddBook" />
        </Grid>

        <!-- List -->
        <ListView Grid.Row="2" x:Name="BooksList"
                  ItemClick="OnBookClicked"
                  IsItemClickEnabled="True"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="shared:UserBookDto">
                    <Grid Padding="8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48" Height="64" Background="#20808080" CornerRadius="4">
                            <Image Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Edition.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind Edition.Publisher}" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind Status}" VerticalAlignment="Center" Opacity="0.6" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="2" x:Name="StatusText"
                   HorizontalAlignment="Center" VerticalAlignment="Top"
                   Margin="0,16,0,0" Opacity="0.7" />
    </Grid>
</Page>
